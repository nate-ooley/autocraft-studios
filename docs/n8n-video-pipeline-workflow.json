        "operation": "update",
        "sheetId": {
          "value": "={{$env.GOOGLE_SHEET_ID}}"
        },
        "sheetName": "Topics",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "status": "failed",
            "error": "={{ $json.data?.error?.detail || 'HeyGen render failed' }}"
          }
        },
        "options": {}
      },
      "id": "handle-failure",
      "name": "Status → Failed",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [2420, 340],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "CONFIGURE_ME",
          "name": "Google Sheets"
        }
      }
    }
  ],
